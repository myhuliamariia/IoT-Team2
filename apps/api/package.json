{
  "name": "@biot/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "db:push": "tsx src/scripts/init-db.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "test": "cross-env NODE_ENV=test vitest run"
  },
  "dependencies": {
    "@biot/shared": "file:../../packages/shared",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.4.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  }
}
